{
  "name": "server",
  "version": "1.0.0",
  "description": "Express backend for Sermon Translator",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
