    "dev": "nodemon server.js"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/client": "^5.22.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "axios": "^1.14.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "prisma": "^5.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "resend": "^6.12.4",
    "socket.io": "^4.7.4",
    "vitest": "^4.1.7"
  },
