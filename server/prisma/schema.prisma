generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String
  createdAt DateTime @default(now())
  sessionsAsImam       Session[] @relation("SessionImam")
  participatedSessions Session[] @relation("SessionParticipants")
  forumPosts           ForumPost[]
  forumComments        ForumComment[]
  @@map("users")
}
model Session {
  id          Int      @id @default(autoincrement())
  imamId      Int
  imam        User     @relation("SessionImam", fields: [imamId], references: [id])
  title       String
  description String   @default("")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  participants User[]  @relation("SessionParticipants")
  translations Translation[]
  @@map("sessions")
}
model Translation {
  id             Int      @id @default(autoincrement())
  sessionId      Int
  session        Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  originalText   String
  translatedText String
  language       String
  createdAt      DateTime @default(now())
  @@map("translations")
}

model ForumPost {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  authorId  Int
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  comments  ForumComment[]
  @@map("forum_posts")
}

model ForumComment {
  id            Int            @id @default(autoincrement())
  content       String
  authorId      Int
  author        User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  postId        Int
  post          ForumPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentId      Int?           
  parent        ForumComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies       ForumComment[] @relation("CommentReplies")
  repliedToName String?        
  createdAt     DateTime       @default(now())
  @@map("forum_comments")
}
