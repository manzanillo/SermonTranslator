# ============================================================================
# Database (Prisma)
# ============================================================================
# SQLite (default for local dev):
DATABASE_URL="file:./dev.db"
# MySQL example:
# DATABASE_URL="mysql://user:password@localhost:3306/sermon_translator"

# ============================================================================
# Server
# ============================================================================
# Port the Express/Socket.IO server listens on (default: 3001)
PORT=3001
# Set to "production" when deploying
NODE_ENV=development

# Path to the statically compiled Next.js client (the `out` folder).
# Defaults to ../client/out relative to server.js when unset.
# CLIENT_BUILD_PATH=/absolute/path/to/client/out

# ============================================================================
# Auth
# ============================================================================
# Secret used to sign JWTs — use a long, random string
JWT_SECRET="change-me-to-a-long-random-secret"

# ============================================================================
# Email (Resend)
# ============================================================================
RESEND_API_KEY="your-resend-api-key"

# ============================================================================
# Translation
# ============================================================================
# Optional override for the LibreTranslate endpoint
# LIBRETRANSLATE_URL="https://translate.argosopentech.com/translate"

# ============================================================================
# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
# ============================================================================
VAPID_SUBJECT="mailto:you@example.com"
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
