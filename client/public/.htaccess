<IfModule mod_rewrite.c>
  # Enable rewrite rules for SPA fallback
  RewriteEngine On
  RewriteBase /

  # Deny access to hidden files and directories (.env, .git, .htaccess, etc.)
  RewriteRule "(^|/)\." - [F]

  # If the request does not map to an existing file or folder, serve index.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_headers.c>
  # Do not cache the main HTML entrypoint so the app always checks for updates
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>

  # Cache hashed build assets in the assets/ folder for a long time
  <FilesMatch "^assets/.*\.(js|css|json|svg|png|jpg|jpeg|gif|webp|woff2?|ttf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
